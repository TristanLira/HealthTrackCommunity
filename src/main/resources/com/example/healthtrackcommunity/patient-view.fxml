<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<GridPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.example.healthtrackcommunity.PatientController"
          stylesheets="@css/patient.css">

    <columnConstraints>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="75"/>
    </columnConstraints>

    <VBox alignment="TOP_CENTER" spacing="20" styleClass="menu-lateral"
          GridPane.columnIndex="0">

        <padding>
            <Insets top="25" right="15" bottom="25" left="15"/>
        </padding>

        <VBox alignment="CENTER" spacing="10">
            <FontIcon iconLiteral="fas-user-circle" iconSize="60" styleClass="icon-perfil"/>
            <Label fx:id="patientNameLabel" text="Paciente" styleClass="nombre-paciente"/>
            <Label text="Paciente" styleClass="rol-usuario"/>

            <VBox alignment="CENTER" spacing="8">
                <HBox alignment="CENTER" spacing="8">
                    <FontIcon iconLiteral="fas-user-md" iconSize="16" styleClass="icon-doctor"/>
                    <Label text="Doctor asignado:" styleClass="label-doctor"/>
                    <Label fx:id="assignedDoctorLabel" text="Ninguno" styleClass="nombre-doctor-asignado"/>
                </HBox>

                <!-- Botón de solicitar doctor (visible solo si no tiene doctor) -->
                <Button fx:id="requestDoctorBtn" text="Solicitar un médico"
                        onAction="#requestDoctor" visible="false" managed="false"
                        styleClass="boton-solicitar">
                    <graphic><FontIcon iconLiteral="fas-user-plus"/></graphic>
                </Button>

                <Label fx:id="requestStatusLabel" text="" styleClass="estado-solicitud" visible="false" managed="false"/>
            </VBox>
        </VBox>

        <Separator styleClass="separador-menu"/>

        <VBox spacing="10" fillWidth="true">
            <Button onAction="#showDashboard" styleClass="menu-button">
                <graphic><FontIcon iconLiteral="fas-home"/></graphic>
                <text>Mi Dashboard</text>
            </Button>

            <Button onAction="#showRegisterMetrics" styleClass="menu-button">
                <graphic><FontIcon iconLiteral="fas-heartbeat"/></graphic>
                <text>Registrar Métricas</text>
            </Button>

            <Button onAction="#showHistory" styleClass="menu-button">
                <graphic><FontIcon iconLiteral="fas-history"/></graphic>
                <text>Historial Clínico</text>
            </Button>

            <Button onAction="#showCharts" styleClass="menu-button">
                <graphic><FontIcon iconLiteral="fas-chart-simple"/></graphic>
                <text>Mis Gráficos</text>
            </Button>

            <Button onAction="#showRecommendations" styleClass="menu-button">
                <graphic><FontIcon iconLiteral="fas-lightbulb"/></graphic>
                <text>Recomendaciones</text>
            </Button>
        </VBox>

        <Separator styleClass="separador-menu"/>

        <Button onAction="#logout" styleClass="menu-button-logout">
            <graphic><FontIcon iconLiteral="fas-sign-out-alt"/></graphic>
            <text>Cerrar Sesión</text>
        </Button>
    </VBox>

    <ScrollPane fx:id="mainScrollPane" fitToWidth="true"
                styleClass="area-principal"
                GridPane.columnIndex="1">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <StackPane fx:id="mainContent">

            <VBox fx:id="dashboardSection" spacing="20" visible="true">
                <Label text="Mi Estado de Salud" styleClass="titulo-seccion"/>

                <VBox fx:id="noDoctorWarning" styleClass="alerta-warning" visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <FontIcon iconLiteral="fas-info-circle" iconSize="28" styleClass="icon-warning"/>
                        <Label text="Aún no tienes un médico asignado." styleClass="texto-warning"/>
                        <Button text="Solicitar ahora" onAction="#requestDoctor" styleClass="boton-warning"/>
                    </HBox>
                </VBox>

                <VBox styleClass="alertas-card">
                    <Label text="Alertas de Salud" styleClass="subtitulo-alerta"/>
                    <Label fx:id="healthAlertLabel"
                           text="✅ Tus métricas están dentro de rangos normales"
                           wrapText="true" styleClass="texto-alerta"/>
                </VBox>

                <VBox styleClass="metricas-recientes">
                    <Label text="Últimas Mediciones" styleClass="subtitulo"/>
                    <TableView fx:id="recentMetricsTable"/>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="recordatorio-card">
                    <FontIcon iconLiteral="fas-bell" iconSize="24" styleClass="icon-recordatorio"/>
                    <Label text="Próximo registro sugerido:" styleClass="label-recordatorio"/>
                    <Label fx:id="nextReminderLabel" text="Hoy 8:00 PM" styleClass="hora-recordatorio"/>
                </HBox>
            </VBox>

            <VBox fx:id="registerMetricsSection" spacing="20" visible="false">
                <Label text="Registrar Mis Métricas" styleClass="titulo-seccion"/>

                <GridPane hgap="15" vgap="15" alignment="CENTER" styleClass="formulario-card">
                    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

                    <Label text="Presión sistólica (mmHg):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="systolicField" promptText="120" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Presión diastólica (mmHg):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="diastolicField" promptText="80" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Glucosa (mg/dL):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="glucoseField" promptText="100" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Peso (kg):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="weightField" promptText="70" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Altura (cm):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="heightField" promptText="170" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="Frecuencia cardíaca (bpm):" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <TextField fx:id="heartRateField" promptText="75" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                    <Label text="Fecha:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="metricDatePicker" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                    <HBox GridPane.rowIndex="7" GridPane.columnIndex="0" GridPane.columnSpan="2"
                          alignment="CENTER" spacing="20">
                        <Button onAction="#saveMetrics" styleClass="boton-primario">
                            <graphic><FontIcon iconLiteral="fas-save"/></graphic>
                            <text>Guardar Registro</text>
                        </Button>
                        <Button onAction="#clearForm" styleClass="boton-secundario">
                            <graphic><FontIcon iconLiteral="fas-eraser"/></graphic>
                            <text>Limpiar</text>
                        </Button>
                    </HBox>
                </GridPane>
            </VBox>

            <VBox fx:id="historySection" spacing="20" visible="false">
                <Label text="Mi Historial Clínico" styleClass="titulo-seccion"/>

                <TabPane>
                    <Tab text="Presión Arterial">
                        <TableView fx:id="historyPressureTable"/>
                    </Tab>
                    <Tab text="Glucosa">
                        <TableView fx:id="historyGlucoseTable"/>
                    </Tab>
                    <Tab text="Frecuencia Cardíaca">
                        <TableView fx:id="historyHeartRateTable"/>
                    </Tab>
                    <Tab text="Peso / IMC">
                        <TableView fx:id="historyWeightTable"/>
                    </Tab>
                </TabPane>

                <Button onAction="#exportHistory" styleClass="boton-secundario">
                    <graphic><FontIcon iconLiteral="fas-download"/></graphic>
                    <text>Exportar Historial (CSV)</text>
                </Button>
            </VBox>

            <VBox fx:id="chartsSection" spacing="20" visible="false">
                <Label text="Mis Gráficos de Evolución" styleClass="titulo-seccion"/>

                <TabPane>
                    <Tab text="Evolución de Glucosa">
                        <VBox fx:id="patientGlucoseChart" alignment="CENTER" spacing="15"/>
                    </Tab>
                    <Tab text="Evolución de Presión Arterial">
                        <VBox fx:id="patientPressureChart" alignment="CENTER" spacing="15"/>
                    </Tab>
                    <Tab text="Evolución de Frecuencia Cardíaca">
                        <VBox fx:id="patientHeartRateChart" alignment="CENTER" spacing="15"/>
                    </Tab>
                    <Tab text="Evolución de Peso / IMC">
                        <VBox fx:id="patientWeightChart" alignment="CENTER" spacing="15"/>
                    </Tab>
                </TabPane>

                <Button onAction="#exportChart" styleClass="boton-secundario">
                    <graphic><FontIcon iconLiteral="fas-download"/></graphic>
                    <text>Exportar Gráfico</text>
                </Button>
            </VBox>

            <VBox fx:id="recommendationsSection" spacing="20" visible="false">
                <Label text="Recomendaciones Personalizadas" styleClass="titulo-seccion"/>

                <ListView fx:id="recommendationsListView" styleClass="lista-recomendaciones"/>
            </VBox>

        </StackPane>
    </ScrollPane>
</GridPane>
