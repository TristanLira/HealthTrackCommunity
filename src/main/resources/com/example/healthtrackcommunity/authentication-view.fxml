<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.RowConstraints?>
<GridPane alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.example.healthtrackcommunity.AuthenticationController">

    <columnConstraints>
        <ColumnConstraints percentWidth="40"/>
        <ColumnConstraints percentWidth="60"/>
    </columnConstraints>

    <GridPane alignment="CENTER" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="auth-section1">

        <rowConstraints>
            <RowConstraints percentHeight="70"/>
            <RowConstraints percentHeight="30"/>
        </rowConstraints>

        <VBox alignment="TOP_CENTER" spacing="20" GridPane.rowIndex="0" GridPane.columnIndex="0">
            <Label text="HealthTrack Community" styleClass="text-title"/>

            <Label text="Acerca de nosotros" styleClass="text-subtitle1"/>

            <Label text="información bla bla bla" wrapText="true" styleClass="text-subtitle2"/>
        </VBox>

        <VBox alignment="TOP_CENTER" spacing="20" GridPane.rowIndex="1" GridPane.columnIndex="0">
            <Label text="¿Qué quiere hacer?" styleClass="text_subtitle3"/>

            <Button text="Iniciar sesión"
                    fx:id="showLoginBtn"
                    onAction="#showLogin"
                    styleClass="section-button">
            </Button>

            <Button text="Registrarse como médico"
                    fx:id="showDoctorRegisterBtn"
                    onAction="#showDoctorRegister"
                    styleClass="section-button">
            </Button>

            <Button text="Registrarse como paciente"
                    fx:id="showPatientRegisterBtn"
                    onAction="#showPatientRegister"
                    styleClass="section-button">
            </Button>

        </VBox>

    </GridPane>

    <StackPane fx:id="formsSection" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="auth-section2">

        <!--inicio de sesión-->
        <VBox alignment="CENTER" fx:id="userLoginForm" spacing = "10" styleClass="authentication-form">
            <Label text="Inicie sesión" styleClass="text-subtitle1"/>

            <GridPane alignment="CENTER">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <Label text="Email" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label text="Contraseña" GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                <TextField fx:id="loginEmailField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <TextField fx:id="loginPasswordField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>

            <Button fx:id="loginBtn" text=" Iniciar sesión" onAction="#login">
            </Button>
        </VBox>

        <!--registro de doctor-->
        <VBox alignment="CENTER" fx:id="doctorRegisterForm" spacing="10" styleClass="authentication-form">
            <Label text="Registrar un nuevo médico" styleClass="text-subtitle1"/>

            <GridPane alignment="CENTER">
                <Label text="Email" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label text="Nombre completo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label text="Especialidad" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label text="Contraseña" GridPane.rowIndex="3" GridPane.columnIndex="0"/>

                <TextField fx:id="doctorEmailField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <TextField fx:id="doctorNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <TextField fx:id="doctorSpecializationField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <TextField fx:id="doctorPasswordField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>

            <Button fx:id="registerDoctorBtn" text = " Registrar" onAction="#registerDoctor">
            </Button>
        </VBox>

        <!--registro de paciente-->
        <VBox alignment="CENTER" fx:id="patientRegisterForm" spacing = "10" styleClass="authentication-form">
            <Label text="Registrar un nuevo paciente" styleClass="text-subtitle1"/>

            <GridPane alignment="CENTER">
                <Label text="Email" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label text="Nombre completo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label text="Contraseña" GridPane.rowIndex="2" GridPane.columnIndex="0"/>

                <TextField fx:id="patientEmailField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <TextField fx:id="patientNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <TextField fx:id="patientPasswordField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <Button fx:id="registerPatientBtn" text = " Registrar" onAction="#registerPatient">
            </Button>
        </VBox>

    </StackPane>


</GridPane>
