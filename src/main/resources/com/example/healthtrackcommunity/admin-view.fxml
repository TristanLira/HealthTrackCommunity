<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<GridPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.example.healthtrackcommunity.AdminController"
          stylesheets="@css/admin.css" maxHeight="Infinity">

    <rowConstraints>
        <RowConstraints vgrow="ALWAYS"/>
    </rowConstraints>
    <columnConstraints>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="75"/>
    </columnConstraints>

    <VBox alignment="TOP_CENTER" spacing="20" styleClass="menu-lateral" GridPane.columnIndex="0">
        <padding>
            <Insets top="25" right="15" bottom="25" left="15"/>
        </padding>

        <VBox alignment="CENTER" spacing="10">
            <FontIcon iconLiteral="fas-user-shield"
                      iconSize="60"
                      styleClass="icon-perfil"/>

            <Label fx:id="adminNameLabel"
                   text="Administrador"
                   styleClass="nombre-admin"/>
        </VBox>

        <Separator styleClass="separador-menu"/>

        <VBox spacing="10">
            <Button onAction="#showDashboard"
                    styleClass="menu-button"
                    maxWidth="Infinity">
                <graphic>
                    <FontIcon iconLiteral="fas-tachometer-alt"
                              styleClass="icono-menu"/>
                </graphic>
                <text>Dashboard</text>
            </Button>

            <Button onAction="#showPendingDoctors"
                    styleClass="menu-button"
                    maxWidth="Infinity">
                <graphic>
                    <FontIcon iconLiteral="fas-user-check"
                              styleClass="icono-menu"/>
                </graphic>
                <text>Doctores Pendientes</text>
            </Button>

            <Button onAction="#showAllDoctors"
                    styleClass="menu-button"
                    maxWidth="Infinity">
                <graphic>
                    <FontIcon iconLiteral="fas-user-md"
                              styleClass="icono-menu"/>
                </graphic>
                <text>Lista de Doctores</text>
            </Button>

            <Button onAction="#showAllPatients"
                    styleClass="menu-button"
                    maxWidth="Infinity">
                <graphic>
                    <FontIcon iconLiteral="fas-users"
                              styleClass="icono-menu"/>
                </graphic>
                <text>Lista de Pacientes</text>
            </Button>
        </VBox>

        <Separator styleClass="separador-menu"/>

        <Button onAction="#logout"
                styleClass="menu-button">
            <graphic>
                <FontIcon iconLiteral="fas-sign-out-alt"
                          styleClass="icono-menu"/>
            </graphic>
            <text>Cerrar Sesión</text>
        </Button>
    </VBox>

    <ScrollPane fitToWidth="true" styleClass="area-principal" GridPane.columnIndex="1">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>
        <StackPane fx:id="mainContent">

            <!-- sección de dashboard -->
            <VBox fx:id="dashboardSection" spacing="20">
                <Label text="Panel de Control" styleClass="titulo-seccion"/>
                <HBox spacing="20">
                    <VBox styleClass="tarjeta-resumen">
                        <FontIcon iconLiteral="fas-user-md" iconSize="40" styleClass="icono-panel"/>
                        <Label text="Doctores Registrados"/>
                        <Label fx:id="totalDoctorsLabel" text="0" styleClass="numero-grande"/>
                    </VBox>
                    <VBox styleClass="tarjeta-resumen">
                        <FontIcon iconLiteral="fas-users" iconSize="40" styleClass="icono-panel"/>
                        <Label text="Pacientes Registrados"/>
                        <Label fx:id="totalPatientsLabel" text="0" styleClass="numero-grande"/>
                    </VBox>
                    <VBox styleClass="tarjeta-resumen">
                        <FontIcon iconLiteral="fas-clock" iconSize="40" styleClass="icono-panel"/>
                        <Label text="Doctores Pendientes"/>
                        <Label fx:id="pendingDoctorsLabel" text="0" styleClass="numero-grande"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- sección de doctores pendientes -->
            <VBox fx:id="pendingDoctorsSection" spacing="20" visible="false">
                <Label text="Solicitudes de Registro de Doctores" styleClass="titulo-seccion"/>
                <VBox fx:id="pendingDoctorsContainer" spacing="10"/>
            </VBox>

            <!-- sección de doctores -->
            <VBox fx:id="allDoctorsSection" spacing="20" visible="false">
                <Label text="Directorio de Doctores" styleClass="titulo-seccion"/>
                <TextField fx:id="searchDoctorField" promptText="Buscar doctor..."/>
                <VBox fx:id="allDoctorsContainer" spacing="5"/>
            </VBox>

            <!-- sección de pacientes -->
            <VBox fx:id="allPatientsSection" spacing="20" visible="false">
                <Label text="Directorio de Pacientes" styleClass="titulo-seccion"/>
                <TextField fx:id="searchPatientField" promptText="Buscar paciente..."/>
                <VBox fx:id="allPatientsContainer" spacing="5"/>
            </VBox>

        </StackPane>
    </ScrollPane>
</GridPane>
