<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<GridPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.example.healthtrackcommunity.DoctorController"
          stylesheets="@css/doctor.css">

    <rowConstraints>
        <RowConstraints vgrow="ALWAYS"/>
    </rowConstraints>

    <columnConstraints>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="75"/>
    </columnConstraints>

    <VBox alignment="TOP_CENTER" spacing="20" styleClass="menu-lateral"
          GridPane.columnIndex="0" maxHeight="Infinity">

        <padding>
            <Insets top="25" right="15" bottom="25" left="15"/>
        </padding>

        <VBox alignment="CENTER" spacing="10">
            <FontIcon iconLiteral="fas-user-md" iconSize="60" styleClass="icon-perfil"/>
            <Label fx:id="doctorNameLabel" text="Dr. Nombre" styleClass="nombre-doctor"/>
            <Label fx:id="doctorSpecializationLabel" text="Especialidad" styleClass="especialidad"/>
        </VBox>

        <Separator styleClass="separador-menu"/>

        <VBox spacing="10" fillWidth="true">
            <Button onAction="#showDashboard" styleClass="menu-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-chalkboard-teacher" styleClass="icono-menu"/></graphic>
                <text>Dashboard</text>
            </Button>

            <Button onAction="#showPendingRequests" styleClass="menu-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-user-plus" styleClass="icono-menu"/></graphic>
                <text>Solicitudes Pendientes</text>
            </Button>

            <Button onAction="#showPatientsList" styleClass="menu-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-users" styleClass="icono-menu"/></graphic>
                <text>Mis Pacientes</text>
            </Button>

            <Button onAction="#showCommentsSection" styleClass="menu-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-comment" styleClass="icono-menu"/></graphic>
                <text>Comentarios enviados</text>
            </Button>

            <Button onAction="#showPatientMetrics" styleClass="menu-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-history" styleClass="icono-menu"/></graphic>
                <text>Métricas de Pacientes</text>
            </Button>

            <Button onAction="#showPatientCharts" styleClass="menu-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-chart-line" styleClass="icono-menu"/></graphic>
                <text>Gráficos de Pacientes</text>
            </Button>

            <!--Button onAction="#showReports" styleClass="menu-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-file-pdf" styleClass="icono-menu"/></graphic>
                <text>Generar Reporte Clínico</text>
            </Button-->
        </VBox>

        <Separator styleClass="separador-menu"/>

        <Button onAction="#logout" styleClass="menu-button">
            <graphic><FontIcon iconLiteral="fas-sign-out-alt" styleClass="icono-menu"/></graphic>
            <text>Cerrar Sesión</text>
        </Button>
    </VBox>

    <ScrollPane fx:id="mainScrollPane" fitToWidth="true"
                styleClass="area-principal"
                GridPane.columnIndex="1" maxHeight="Infinity">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <StackPane fx:id="mainContent" maxHeight="Infinity" styleClass="area-principal">

            <!--SECCIÓN DE DASHBOARD-->
            <VBox fx:id="dashboardSection" spacing="20" visible="true" maxHeight="Infinity">
                <Label text="Resumen Clínico" styleClass="titulo-seccion"/>

                <HBox spacing="20">
                    <VBox styleClass="tarjeta-resumen">
                        <FontIcon iconLiteral="fas-user" iconSize="40" styleClass="icon-tarjeta"/>
                        <Label text="Total Pacientes" styleClass="label-tarjeta"/>
                        <Label fx:id="totalPatientsLabel" text="0" styleClass="numero-tarjeta"/>
                    </VBox>
                    <VBox styleClass="tarjeta-resumen">
                        <FontIcon iconLiteral="fas-exclamation-triangle" iconSize="40" styleClass="icon-tarjeta-alerta"/>
                        <Label text="Alertas Activas" styleClass="label-tarjeta"/>
                        <Label fx:id="activeAlertsLabel" text="0" styleClass="numero-tarjeta-alerta"/>
                    </VBox>
                    <!--VBox styleClass="tarjeta-resumen">
                        <FontIcon iconLiteral="fas-clock" iconSize="40" styleClass="icon-tarjeta"/>
                        <Label text="Consultas Pendientes" styleClass="label-tarjeta"/>
                        <Label fx:id="pendingConsultationsLabel" text="0" styleClass="numero-tarjeta"/>
                    </VBox-->
                </HBox>

                <VBox styleClass="grafico-card">
                    <Label text="Pacientes con Alertas" styleClass="subtitulo"/>
                    <!--ListView fx:id="alertPatientsListView" styleClass="lista-pacientes"/-->
                    <VBox fx:id="alertsContainer" styleClass="lista-pacientes" spacing="15">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>
                    </VBox>
                </VBox>
            </VBox>

            <!--SECCIÓN DE PACIENTES-->
            <VBox fx:id="patientsListSection" spacing="15" visible="false">
                <Label text="Mis Pacientes" styleClass="titulo-seccion"/>

                <HBox maxWidth="Infinity" alignment="CENTER" spacing="20">
                    <TextField fx:id="searchPatientField" promptText="Buscar paciente por nombre..."
                               styleClass="campo-busqueda" HBox.hgrow="ALWAYS" onAction="#filterPatientsList"/>

                    <Button fx:id="filterPatientsListBtn" styleClass="boton-primario" onAction="#filterPatientsList">
                        <graphic>
                            <FontIcon iconLiteral="fas-search" styleClass="icono-menu"/>
                        </graphic>
                    </Button>

                    <Button fx:id="removePatientsFilterBtn" styleClass="boton-primario" onAction="#removePatientsFilters">
                        <graphic>
                            <FontIcon iconLiteral="fas-trash-alt" styleClass="icono-menu"/>
                        </graphic>
                    </Button>
                </HBox>

                <VBox fx:id="patientsListContainer" spacing="10"/>
            </VBox>

            <!--SECCIÓN DE COMENTARIOS -->
            <VBox fx:id="commentsSection" spacing="20" visible="false">
                <Label text="Comentarios enviados" styleClass="titulo-seccion"/>

                <HBox maxWidth="Infinity" alignment="CENTER_LEFT" spacing="20">

                    <VBox spacing="5">
                        <Label text="Filtrar por paciente visualizado" styleClass="subtitulo"/>
                        <Label fx:id="currentPatientCommentLabel" styleClass="texto-ayuda" maxWidth="-Infinity"/>
                    </VBox>

                    <Button fx:id="filterCommentsBtn" styleClass="boton-primario" onAction="#filterComments">
                        <graphic>
                            <FontIcon iconLiteral="fas-search" styleClass="icono-menu"/>
                        </graphic>
                    </Button>

                    <Button fx:id="removeCommentsFilterBtn" styleClass="boton-primario" onAction="#removeCommentsFilter">
                        <graphic>
                            <FontIcon iconLiteral="fas-trash-alt" styleClass="icono-menu"/>
                        </graphic>
                    </Button>
                </HBox>

                <VBox fx:id="doctorCommentsContainer" spacing="10"/>
            </VBox>

            <!--SECCIÓN DE SOLICITUDES-->
            <VBox fx:id="pendingRequestsSection" spacing="15" visible="false">
                <Label text="Solicitudes de seguimiento médico" styleClass="titulo-seccion"/>

                <Label text="Pacientes que han solicitado ser atendidos por ti."
                       styleClass="texto-ayuda" wrapText="true"/>

                <VBox fx:id="requestsContainer" spacing="10"/>
            </VBox>

            <!--SECCIÓN DE MÉTRICAS-->
            <VBox fx:id="patientMetricsSection" spacing="20" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label text="Métricas del Paciente" styleClass="titulo-seccion"/>
                </HBox>

                <HBox spacing="5" alignment="BOTTOM_LEFT">
                    <Label text="Visualizando al paciente: " styleClass="patient-name"/>
                    <Label fx:id="currentPatientMetricLabel" styleClass="patient-email" maxWidth="-Infinity"/>
                </HBox>

                <TabPane tabClosingPolicy="UNAVAILABLE" fx:id="metricsTab">
                    <Tab text="Presión Arterial">
                        <VBox spacing="15">
                            <VBox fx:id="bloodPressureMetricContainer" alignment="CENTER"/>
                        </VBox>
                    </Tab>
                    <Tab text="Glucosa">
                        <VBox spacing="15">
                            <VBox fx:id="glucoseMetricContainer" alignment="CENTER"/>
                        </VBox>
                    </Tab>
                    <Tab text="Frecuencia Cardíaca">
                        <VBox spacing="15">
                            <VBox fx:id="heartRateMetricContainer" alignment="CENTER"/>
                        </VBox>
                    </Tab>
                    <Tab text="Peso / IMC">
                        <VBox spacing="15">
                            <VBox fx:id="weightMetricContainer" alignment="CENTER"/>
                        </VBox>
                    </Tab>
                </TabPane>

                <Button styleClass="boton-primario">
                    <graphic><FontIcon iconLiteral="fas-file-pdf" styleClass="icono-menu"/></graphic>
                    <text> Generar Reporte Clínico (PDF)</text>
                </Button>
            </VBox>

            <!--SECCIÓN DE GRÁFICOS-->
            <VBox fx:id="patientChartsSection" spacing="20" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label text="Gráficos del Paciente" styleClass="titulo-seccion"/>
                </HBox>

                <HBox spacing="5" alignment="BOTTOM_LEFT">
                    <Label text="Visualizando al paciente: " styleClass="patient-name"/>
                    <Label fx:id="currentPatientChartLabel" styleClass="patient-email" maxWidth="-Infinity"/>
                </HBox>

                <TabPane tabClosingPolicy="UNAVAILABLE" fx:id="chartsTab">
                    <Tab text="Presión Arterial">
                        <VBox spacing="15">
                            <ScrollPane fitToWidth="true">
                                <VBox fx:id="bloodPressureChartContainer" alignment="CENTER"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>
                    <Tab text="Glucosa">
                        <VBox spacing="15">
                            <ScrollPane fitToWidth="true">
                                <VBox fx:id="glucoseChartContainer" alignment="CENTER"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>
                    <Tab text="Frecuencia Cardíaca">
                        <VBox spacing="15">
                            <ScrollPane fitToWidth="true">
                                <VBox fx:id="heartRateChartContainer" alignment="CENTER"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>
                    <Tab text="Peso / IMC">
                        <VBox spacing="15">
                            <ScrollPane fitToWidth="true">
                                <VBox fx:id="weightChartContainer" alignment="CENTER"/>
                            </ScrollPane>
                        </VBox>
                    </Tab>
                </TabPane>

                <!--Button styleClass="boton-primario">
                    <graphic><FontIcon iconLiteral="fas-file-pdf" styleClass="icono-menu"/></graphic>
                    <text> Generar Reporte Clínico (PDF)</text>
                </Button-->
            </VBox>

        </StackPane>
    </ScrollPane>
</GridPane>